{
  "name": "react-bear",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "bear.app Tag TOC Creator",
  "author": "Fabio",
  "main": "main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist release",
    "lint": "tsc --noEmit",
    "electron": "electron .",
    "electron:build": "npm run clean && npm run build && electron-builder"
  },
  "build": {
    "appId": "com.bear.myapp",
    "productName": "bear.app Tag TOC Creator",
    "asar": true,
    "icon": "public/icon.png",
    "files": [
      {
        "from": ".",
        "filter": [
          "main.cjs",
          "preload.js",
          "package.json",
          "public/icon.png"
        ]
      },
      {
        "from": "dist",
        "to": "dist"
      }
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "mac": {
      "icon": "public/icon.icns",
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "30.0.0",
    "electron-builder": "24.6.4",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
